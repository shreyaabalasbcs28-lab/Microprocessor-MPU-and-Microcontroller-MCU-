                OUTPUT 2500AD
.ORG 2000H
DATA SEGMENT
STR1  DB 'BRNYNG'
LEN DW 6
RESULT DB 01H
DATA ENDS
CODE SEGMENT
    ASSUME CS:CODE, DS:DATA
    MOV AX, DATA
    MOV DS, AX
    LEA SI, STR1
        MOV CX,LEN
    MOV BL, 'E'
REPLACE_LOOP:
    MOV AL, [SI]
    CMP AL, 'B'
    JNE NEXT_CHAR
    MOV RESULT, 00H
    MOV [SI], BL
NEXT_CHAR:
    INC SI
    LOOP REPLACE_LOOP
    HLT
CODE ENDS
END
