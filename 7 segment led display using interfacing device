                OUTPUT 2500AD

.ORG 2000h
DATA SEGMENT
LIST1 DB 06H,7FH,39H
LIST2 DB 06H,79H,6DH
COUNT DB 03H
DATA ENDS
CODE SEGMENT
        ASSUME CS:CODE, DS:DATA
START:
    MOV AX, DATA
    MOV DS, AX

    MOV AL, 80H
    MOV DX, FFE6H
    OUT DX, AL
REPEAT:
    LEA SI, LIST1
    MOV CL, 03H

L2:
    MOV AL, [SI]
    MOV DX, FFE0H
    OUT DX, AL
    CALL DELAY
    LEA DI, LIST2
    MOV CH, 03H

L1:
    MOV AL, [DI]
    MOV DX, FFE2H
    OUT DX, AL
    CALL DELAY
    INC DI
    DEC CH
    JNZ L1

    INC SI
    DEC CL
    JNZ L2

    JMP REPEAT
DELAY:
    MOV AH, 15H
L4:
    MOV BX, AAAAH
L3:
    DEC BX
    JNZ L3
    DEC AH
    JNZ L4
    RET

CODE ENDS
END
