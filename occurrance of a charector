                OUTPUT 2500AD
.ORG 2000H
DATA SEGMENT
STRING1 DB "HELLO"
CHAR DB 'L'
RESULT DB 00H
COUNT EQU 05H
DATA ENDS
CODE SEGMENT
        ASSUME CS:CODE,DS:DATA,ES:DATA
        MOV AX,DATA
        MOV DS,AX
        LEA DI,STRING1
        MOV AL,CHAR
        MOV CL,COUNT
        CLD
L2:     SCASB
        JZ L1
        DEC COUNT
        JNZ L2
        MOV RESULT,00H
L1:     MOV RESULT,01H
        JMP L3
L3:     HLT
CODE ENDS
END
