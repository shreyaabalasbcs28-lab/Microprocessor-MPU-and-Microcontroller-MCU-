                OUTPUT 2500AD
.ORG 2000H
DATA SEGMENT
LIST DB 01H,02H,04H,08H
LIST1 DB 08H,04H,02H,01H
DATA ENDS
CODE SEGMENT
        ASSUME CS:CODE,DS:DATA
        MOV AX,DATA
        MOV DS,AX
        MOV AL,80H
        MOV DX,FFE6H
        OUT DX,AL
L3:
        MOV CH,0CH
L2:
        MOV SI,OFFSET LIST
        MOV CL,04H
L1:
        MOV AL,[SI]
        MOV DX,FFE0H
        OUT DX,AL
        CALL DELAY
        INC SI
        DEC CL
        JNZ L1
        DEC CH
        JNZ L2
        MOV CH,0CH
L4:
        MOV SI,OFFSET LIST1
        MOV CL,04H
L5:
        MOV AL,[SI]
        MOV DX,FFE0H
        OUT DX,AL
        CALL DELAY
        INC SI
        DEC CL
        JNZ L5
        DEC CH
        JNZ L4
        JMP L3
DELAY:
        MOV BX,AAAAH
L6:
        DEC BX
        JNZ L6
        RET
CODE ENDS
END
